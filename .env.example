# Copy to .env and fill in your keys (or create .env in AppV1/ with the same variables)
# NYT: https://developer.nytimes.com/get-started
# OpenAI: https://platform.openai.com/api-keys

NYT_API_KEY=your_nyt_key_here
OPENAI_API_KEY=your_openai_key_here

# Upstash Redis (optional — enables 24h lazy-loaded AI caching on Render)
# Create a free database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# Optional: override default 24-hour TTL (seconds)
# REDIS_CACHE_TTL_SECONDS=86400
